<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="SERVICE_NAME" source="spring.application.name" defaultValue="api-gateway"/>
    <springProperty scope="context" name="SERVICE_VERSION" source="spring.application.version" defaultValue="1.0.0"/>
    <springProperty scope="context" name="LOGSTASH_HOST" source="logstash.host" defaultValue="logstash"/>
    <springProperty scope="context" name="LOGSTASH_PORT" source="logstash.port" defaultValue="5000"/>

    <!-- Console appender — human-readable JSON via logstash-logback-encoder -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service_name":"${SERVICE_NAME}","service_version":"${SERVICE_VERSION}"}</customFields>
            <includeCallerData>false</includeCallerData>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <version>[ignore]</version>
            </fieldNames>
        </encoder>
    </appender>

    <!-- Logstash TCP appender for ELK ingestion -->
    <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>${LOGSTASH_HOST}:${LOGSTASH_PORT}</destination>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service_name":"${SERVICE_NAME}","service_version":"${SERVICE_VERSION}"}</customFields>
        </encoder>
        <keepAliveDuration>5 minutes</keepAliveDuration>
        <reconnectionDelay>10 second</reconnectionDelay>
    </appender>

    <!-- Async wrapper — prevents Logstash I/O from blocking reactive threads -->
    <appender name="ASYNC_LOGSTASH" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="LOGSTASH"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <springProfile name="local,dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_LOGSTASH"/>
        </root>
        <logger name="com.taskmaster" level="DEBUG"/>
        <logger name="org.springframework.cloud.gateway" level="DEBUG"/>
        <logger name="reactor.netty" level="INFO"/>
    </springProfile>

    <springProfile name="stage,prod">
        <root level="INFO">
            <appender-ref ref="ASYNC_LOGSTASH"/>
        </root>
        <logger name="com.taskmaster" level="INFO"/>
    </springProfile>
</configuration>
