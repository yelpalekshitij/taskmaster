{
  "realm": "taskmaster-app",
  "displayName": "TaskMaster App",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Standard application user"
      },
      {
        "name": "READONLY",
        "description": "Read-only access to tasks and reports"
      }
    ]
  },
  "clients": [
    {
      "clientId": "taskmaster-user-frontend",
      "name": "TaskMaster User Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://user-frontend:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://user-frontend:4200"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/login##http://user-frontend:4200/login"
      },
      "defaultClientScopes": [
        "openid",
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "tenant-id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "taskmaster-backend",
      "name": "TaskMaster Backend Service",
      "enabled": true,
      "publicClient": false,
      "secret": "${KEYCLOAK_BACKEND_SECRET}",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "config": {
        "clientId": "${GOOGLE_CLIENT_ID}",
        "clientSecret": "${GOOGLE_CLIENT_SECRET}",
        "defaultScope": "openid email profile",
        "syncMode": "IMPORT"
      }
    }
  ],
  "users": [
    {
      "id": "bbbbbbbb-0000-0000-0000-000000000002",
      "username": "bob.smith",
      "email": "bob@acme.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Smith",
      "credentials": [
        {
          "type": "password",
          "value": "Seed@1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER"
      ],
      "attributes": {
        "tenant_id": [
          "aaaaaaaa-0000-0000-0000-000000000001"
        ]
      }
    },
    {
      "id": "bbbbbbbb-0000-0000-0000-000000000004",
      "username": "dave.brown",
      "email": "dave@techstart.io",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Dave",
      "lastName": "Brown",
      "credentials": [
        {
          "type": "password",
          "value": "Seed@1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "READONLY"
      ],
      "attributes": {
        "tenant_id": [
          "aaaaaaaa-0000-0000-0000-000000000002"
        ]
      }
    }
  ]
}